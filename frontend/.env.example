# Sample configuration — copy to .env and fill in your values
# Do NOT commit .env to version control

# Backend API base URL
VITE_API_URL=http://127.0.0.1:8000

# Logic App Feedback URL (get this from Azure Portal)
VITE_LOGIC_APP_FEEDBACK_URL=https://prod-XX.region.logic.azure.com:443/...

# Deployment environment label shown in the UI ribbon.
# Omit (or set to 'prod') for production — the ribbon is hidden.
# Valid non-production values: local | e2e | dev
VITE_APP_ENV=local
