# PostgreSQL connection settings for local development ONLY.
# Copy this file to .env and adjust values if needed.
#
# ⚠️  Never commit .env or use these credentials in staging / production.
#     Use your cloud provider's secrets management for non-local environments.

# ── Admin role ────────────────────────────────────────────────────────────────
# Created automatically by the PostgreSQL container at first start.
# Used by Alembic (schema migrations) and CI/CD pipelines.
POSTGRES_ADMIN_USER=tul_psi_admin
POSTGRES_ADMIN_PASSWORD=tul_psi_admin
POSTGRES_DB=student_projects
POSTGRES_PORT=5432

# ── Application role ──────────────────────────────────────────────────────────
# Created by database/init-db.sh at first container start.
# DML only (SELECT, INSERT, UPDATE, DELETE) — no DDL / schema changes.
# Used by the FastAPI backend at runtime.
POSTGRES_APP_USER=tul_psi_app
POSTGRES_APP_PASSWORD=tul_psi_app

# ── Connection URLs consumed by the FastAPI backend ───────────────────────────
# Admin URL — full DDL+DML access, used by Alembic migrations.
DATABASE_ADMIN_URL=postgresql://${POSTGRES_ADMIN_USER}:${POSTGRES_ADMIN_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}
# App URL — DML-only access, used by the FastAPI application at runtime.
DATABASE_URL=postgresql://${POSTGRES_APP_USER}:${POSTGRES_APP_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}
