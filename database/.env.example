# PostgreSQL connection settings for local development ONLY.
# Copy this file to .env and adjust values if needed.
#
# ⚠️  Never commit .env or use these credentials in staging / production.
#     Use your cloud provider's secrets management for non-local environments.

POSTGRES_DB=tul_psi
POSTGRES_USER=tul_psi
POSTGRES_PASSWORD=tul_psi
POSTGRES_PORT=5432

# Full connection URL consumed by the FastAPI backend (SQLModel / SQLAlchemy).
DATABASE_URL=postgresql://tul_psi:tul_psi@localhost:5432/tul_psi
